# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Строка подключения к Postgres.
# Локально:   postgresql://postgres:postgres@localhost:5432/plantbot
# На Railway: подставляется автоматически через reference на сервис Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/plantbot

# Публичный HTTPS-адрес Mini App (домен сервиса на Railway).
# Локально можно оставить пустым — кнопка Mini App просто не будет показана.
WEBAPP_URL=

# Порт веб-сервера (Railway подставляет свой автоматически)
PORT=8000
